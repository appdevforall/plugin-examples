<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="0dp">

    <TextView
        android:id="@+id/forms_wizard_step2_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/forms_wizard_review_hint"
        android:textColor="@color/forms_text_secondary"
        android:padding="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/forms_wizard_step2_fields"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical" />

    <TextView
        android:id="@+id/forms_wizard_step2_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/forms_wizard_no_fields_yet"
        android:textColor="@color/forms_text_secondary"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/forms_wizard_step2_add"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:text="@string/forms_wizard_add_field" />
</LinearLayout>
