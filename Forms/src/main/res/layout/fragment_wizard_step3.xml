<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:textColor="@color/forms_text_secondary"
        android:text="Tap each field to set its rules. Required fields show validation errors at runtime; reusable fields keep their value across records." />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/forms_wizard_step3_rules"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="vertical" />
</LinearLayout>
