<?xml version="1.0" encoding="utf-8"?>
<!--
  Light-mode palette. Semantic names shared with the other CoGo AI/house plugins (see
  client-time-tracker) so both modes have vetted contrast. values-night/colors.xml holds the
  dark variants; the host keeps the plugin's inflation Context in sync with the IDE's day/night
  setting, so a plain @color/plugin_* reference flips automatically.
-->
<resources>
    <color name="plugin_primary">#C2410C</color>
    <color name="plugin_on_primary">#FFFFFF</color>
    <color name="plugin_primary_container">#FFE5D6</color>
    <color name="plugin_on_primary_container">#471400</color>

    <color name="plugin_secondary">#404040</color>
    <color name="plugin_on_secondary">#FAFAF9</color>
    <color name="plugin_secondary_container">#F5F5F4</color>
    <color name="plugin_on_secondary_container">#0A0A0A</color>

    <color name="plugin_surface">#FAFAF9</color>
    <color name="plugin_on_surface">#0A0A0A</color>
    <color name="plugin_surface_variant">#F5F5F4</color>
    <color name="plugin_on_surface_variant">#525252</color>
    <color name="plugin_surface_dim">#F0F0EE</color>

    <color name="plugin_outline">#A3A3A3</color>
    <color name="plugin_outline_variant">#E5E5E5</color>

    <color name="plugin_error">#B91C1C</color>
    <color name="plugin_on_error">#FFFFFF</color>
    <color name="plugin_error_container">#FEE2E2</color>
    <color name="plugin_on_error_container">#7F1D1D</color>

    <color name="plugin_success">#15803D</color>
    <color name="plugin_success_container">#DCFCE7</color>

    <color name="plugin_text_muted">#737373</color>
    <color name="plugin_text_subtle">#A3A3A3</color>

    <color name="plugin_ripple">#1F0A0A0A</color>
</resources>
