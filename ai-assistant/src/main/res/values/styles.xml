<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
      DayNight theme applied to the plugin's inflation Context via android:theme on
      <application>. The host builds the plugin Context from this theme and keeps its
      Configuration in sync with the IDE's day/night setting, so switching the parent to a
      Material3 DayNight theme (was android:Theme.Material.Light, which pinned everything to
      light) is what lets the UI follow the IDE. Colors map to @color/plugin_* which have
      values-night/ variants.
    -->
    <style name="PluginTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/plugin_primary</item>
        <item name="colorOnPrimary">@color/plugin_on_primary</item>
        <item name="colorPrimaryContainer">@color/plugin_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/plugin_on_primary_container</item>

        <item name="colorSecondary">@color/plugin_secondary</item>
        <item name="colorOnSecondary">@color/plugin_on_secondary</item>
        <item name="colorSecondaryContainer">@color/plugin_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/plugin_on_secondary_container</item>

        <item name="android:colorBackground">@color/plugin_surface</item>
        <item name="colorSurface">@color/plugin_surface</item>
        <item name="colorOnSurface">@color/plugin_on_surface</item>
        <item name="colorSurfaceVariant">@color/plugin_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/plugin_on_surface_variant</item>

        <item name="colorOutline">@color/plugin_outline</item>
        <item name="colorOutlineVariant">@color/plugin_outline_variant</item>

        <item name="colorError">@color/plugin_error</item>
        <item name="colorOnError">@color/plugin_on_error</item>
        <item name="colorErrorContainer">@color/plugin_error_container</item>
        <item name="colorOnErrorContainer">@color/plugin_on_error_container</item>
    </style>

</resources>
