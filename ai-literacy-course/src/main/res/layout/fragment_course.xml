<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/course_background">

    <!-- Full-screen course surface. -->
    <WebView
        android:id="@+id/course_web_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- First-run extraction overlay (hidden once the course is ready). -->
    <LinearLayout
        android:id="@+id/course_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="@color/course_background">

        <ProgressBar
            android:id="@+id/course_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/course_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:text="@string/preparing_course" />

        <TextView
            android:id="@+id/course_status_detail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:text="@string/preparing_detail" />
    </LinearLayout>

</FrameLayout>
