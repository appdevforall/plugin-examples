<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:label="@string/contractor_plugin_label"
        android:theme="@style/PluginTheme">

        <meta-data
            android:name="plugin.id"
            android:value="com.appdevforall.contractor.plugin" />

        <meta-data
            android:name="plugin.name"
            android:value="Client Time Tracker" />

        <meta-data
            android:name="plugin.version"
            android:value="${pluginVersion}" />

        <meta-data
            android:name="plugin.description"
            android:value="Track billable coding sessions and generate invoices in PDF, Excel, or CSV." />

        <meta-data
            android:name="plugin.author"
            android:value="App Dev For All" />

        <meta-data
            android:name="plugin.min_ide_version"
            android:value="1.0.0" />

        <meta-data
            android:name="plugin.permissions"
            android:value="filesystem.read,filesystem.write,ide.environment.write" />

        <meta-data
            android:name="plugin.main_class"
            android:value="com.appdevforall.contractor.plugin.ContractorPlugin" />

        <meta-data
            android:name="plugin.sidebar_items"
            android:value="1" />

        <meta-data
            android:name="plugin.icon_day"
            android:value="assets/icon_day.png" />

        <meta-data
            android:name="plugin.icon_night"
            android:value="assets/icon_night.png" />

        <!-- No <provider> here: the plugin is dex-loaded, not installed, so any provider
             declared in this manifest is invisible to the system's PackageManager and
             unreachable from other apps. The plugin reuses the host's registered
             FileProvider (`${HOST_APPLICATION_ID}.providers.fileprovider`) which has
             root-path whitelisted; see InvoiceSuccessSheet.hostFileProviderAuthority(). -->

    </application>

</manifest>
