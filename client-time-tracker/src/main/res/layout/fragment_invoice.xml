<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/invoice_picker_project"
            android:textAppearance="@style/Plugin.Text.Label" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/project_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            app:endIconMode="custom"
            app:endIconDrawable="@drawable/ic_arrow_drop_down"
            app:endIconTint="?attr/colorOnSurfaceVariant"
            style="@style/PluginTextInputLayout">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/project_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:focusable="false"
                android:longClickable="false"
                android:cursorVisible="false"
                android:clickable="true" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            style="@style/Plugin.SectionHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/invoice_picker_range" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/range_chips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleLine="true"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_inv_week"
                    style="@style/PluginChip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sessions_range_week" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_inv_month"
                    style="@style/PluginChip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/sessions_range_month" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_inv_lastmonth"
                    style="@style/PluginChip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last month" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_inv_custom"
                    style="@style/PluginChip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sessions_range_custom" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/range_summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:textAppearance="@style/Plugin.Text.Mono"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            style="@style/Plugin.SectionHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/invoice_field_number" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/PluginTextInputLayout">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/invoice_number_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            style="@style/Plugin.SectionHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/invoice_field_notes" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/PluginTextInputLayout">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/notes_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:maxLines="3" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            style="@style/Plugin.SectionHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/invoice_label_formats" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.chip.Chip
                android:id="@+id/format_pdf"
                style="@style/PluginChip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/invoice_format_pdf"
                android:checkable="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/format_xlsx"
                style="@style/PluginChip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_sm"
                android:text="@string/invoice_format_xlsx"
                android:checkable="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/format_csv"
                style="@style/PluginChip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_sm"
                android:text="@string/invoice_format_csv"
                android:checkable="true" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_generate"
            style="@style/PluginButton.Filled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:text="@string/invoice_action_generate" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:indeterminate="true"
            android:visibility="gone"
            app:trackThickness="2dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
