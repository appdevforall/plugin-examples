<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingTop="@dimen/space_md">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/range_chips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/space_lg"
            app:singleLine="true"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_today"
                style="@style/PluginChip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sessions_range_today" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_week"
                style="@style/PluginChip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sessions_range_week" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_month"
                style="@style/PluginChip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/sessions_range_month" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_custom"
                style="@style/PluginChip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sessions_range_custom" />
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginHorizontal="@dimen/space_lg"
        android:layout_marginTop="@dimen/space_md"
        android:baselineAligned="false">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/project_filter_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/sessions_filter_project"
            app:endIconMode="custom"
            app:endIconDrawable="@drawable/ic_arrow_drop_down"
            app:endIconTint="@color/plugin_text_muted"
            style="@style/PluginTextInputLayout">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/project_filter_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:focusable="false"
                android:longClickable="false"
                android:cursorVisible="false"
                android:inputType="none"
                android:clickable="true"
                android:textColor="@color/plugin_on_surface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_session"
            style="@style/PluginButton.Filled"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="@dimen/space_sm"
            android:paddingHorizontal="@dimen/space_md"
            android:text="@string/sessions_action_add_manual"
            app:icon="@drawable/ic_add"
            app:iconGravity="textStart"
            app:iconSize="16dp"
            app:iconPadding="@dimen/space_xs" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/space_lg"
        android:paddingTop="@dimen/space_lg"
        android:paddingBottom="@dimen/space_sm"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/sessions_total_label"
            android:textAppearance="@style/Plugin.Text.Label" />

        <TextView
            android:id="@+id/total_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Plugin.Text.MonoHero" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="@dimen/space_lg"
        android:background="?attr/colorOutlineVariant" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/space_xl" />

        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="@dimen/space_xxl"
            android:layout_gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sessions_empty_title"
                android:textAppearance="@style/Plugin.Text.Title"
                android:gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:text="@string/sessions_empty_body"
                android:textAppearance="@style/Plugin.Text.BodyMuted"
                android:gravity="center" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
