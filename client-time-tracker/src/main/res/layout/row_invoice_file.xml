<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:minHeight="56dp"
    android:paddingHorizontal="@dimen/space_lg"
    android:paddingVertical="@dimen/space_md"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/file_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:textColor="@color/plugin_on_surface"
        android:maxLines="1"
        android:ellipsize="middle" />

    <TextView
        android:id="@+id/open_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_md"
        android:text="@string/invoice_action_open"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/plugin_primary" />

    <ImageView
        android:id="@+id/open_icon"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginStart="6dp"
        android:src="@drawable/ic_open_in_new"
        android:contentDescription="@string/invoice_action_open"
        app:tint="@color/plugin_primary"
        xmlns:app="http://schemas.android.com/apk/res-auto" />
</LinearLayout>
