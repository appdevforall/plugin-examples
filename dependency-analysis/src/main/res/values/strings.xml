    <string name="da_fix_confirm_eyebrow">Apply fixes</string>
    <string name="da_fix_confirm_title">Apply all recommended fixes?</string>
    <string name="da_fix_confirm_body">This edits your build.gradle file(s) in place — removing unused dependencies, adding undeclared ones, and moving misconfigured ones. We re-analyze afterward to confirm.</string>
    <string name="da_fix_confirm_apply">Apply fixes</string>

    <!-- Applied summary -->
    <string name="da_applied_eyebrow">Fixes applied</string>
