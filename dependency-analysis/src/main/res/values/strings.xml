    <string name="da_intro_body">Run a full dependency health check on the open project. We report dependencies that are unused, used but undeclared (transitive), or declared on the wrong configuration — then offer a one-tap fix.</string>
    <string name="da_action_analyze">Analyze dependencies</string>
    <string name="da_action_reanalyze">Re-analyze</string>

