    <string name="da_running_body">Running :buildHealth. The first run configures the build and may take a minute.</string>
    <string name="da_action_cancel">Cancel</string>

    <!-- Results group headers -->
    <string name="da_group_unused">Unused</string>
    <string name="da_group_undeclared">Undeclared transitive</string>
    <string name="da_group_misconfigured">Misconfigured</string>
    <string name="da_group_unused_hint">Declared but not used — safe to remove.</string>
    <string name="da_group_undeclared_hint">Used directly but only present transitively — declare them.</string>
    <string name="da_group_misconfigured_hint">Declared on the wrong configuration — move them.</string>

    <!-- Results summary -->
    <string name="da_results_eyebrow">Results</string>
