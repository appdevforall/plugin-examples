<?xml version="1.0" encoding="utf-8"?>
<!--
    Background for v3 wizard radio rows + the shared reach-summary panel.
    Rounded surface-variant rectangle with a hairline outline. Mirrors the
    v3 mockup's .radio-row style.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="?attr/colorSurfaceVariant" />
    <stroke
        android:width="1dp"
        android:color="?attr/colorOutlineVariant" />
    <corners android:radius="10dp" />
</shape>
