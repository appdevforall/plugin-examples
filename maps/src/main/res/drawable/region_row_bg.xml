<?xml version="1.0" encoding="utf-8"?>
<!--
    Default region-row background — neutral surface-variant with hairline outline.
    The adapter swaps this for badge_active style border when the row is the
    project's active region (see RegionAdapter.bind).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="?attr/colorSurfaceVariant" />
    <stroke
        android:width="1dp"
        android:color="?attr/colorOutlineVariant" />
    <corners android:radius="10dp" />
</shape>
