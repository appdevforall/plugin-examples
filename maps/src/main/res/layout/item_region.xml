<?xml version="1.0" encoding="utf-8"?>
<!--
    v3 Region row layout:
    - Active region gets a thick green border via @drawable/region_row_bg_active
    - Top row: name + size
    - Meta row: bbox + extent + downloaded-at
    - Badge row: "Active in this project" (active rows only) + source badge
    - Action row (NEW v3): active/inactive toggle on the right, Refresh/Delete on the left
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/row_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    android:padding="12dp"
    android:background="@drawable/region_row_bg"
    android:orientation="vertical">

    <!-- Top row: name + size -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/region_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorOnSurface"
            tools:text="Lalibela, Ethiopia" />

        <TextView
            android:id="@+id/region_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="32 MB" />

        <!-- Inline progress when a fresh download is running for this region. -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/region_progress"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="8dp"
            android:indeterminate="true"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/region_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        tools:text="12.0°N · 39.0°E · 20 × 20 km · downloaded today" />

    <!-- Badge + toggle row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/active_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:background="@drawable/badge_active"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:text="@string/maps_region_active_in_project"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/source_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:background="@drawable/badge_unknown"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:visibility="gone"
                tools:text="● LAN"
                tools:visibility="visible" />
        </LinearLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sw_active"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Secondary actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_redownload"
            style="@style/Plugin.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/maps_regions_redownload" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete"
            style="@style/Plugin.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="@string/maps_regions_delete"
            android:textColor="?attr/colorError" />
    </LinearLayout>
</LinearLayout>
