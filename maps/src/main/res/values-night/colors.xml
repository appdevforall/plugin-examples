    <color name="plugin_on_surface">#E1E3DF</color>
    <color name="plugin_surface_variant">#404943</color>
    <color name="plugin_on_surface_variant">#BFC9C1</color>
    <color name="plugin_outline">#89938D</color>
    <color name="plugin_outline_variant">#404943</color>
