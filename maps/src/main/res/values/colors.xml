<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Colors the Maps plugin's OWN views (its fragments, its drawables, and the
        bbox-overlay custom view). Intentionally NOT a full M3 palette: the plugin
        does not brand host-loaded Material widgets — buttons take the host's
        colors, like every plugin in this repo (see styles.xml for why). What
        remains is only what the plugin actually references:

          - surface / on-surface / outline family — the plugin's own layouts and
            drawables resolve these via ?attr/* against PluginTheme; the
            values-night variants keep the plugin's UI dark-mode correct.
          - plugin_primary / plugin_primary_container — the plugin's own forest-green
            accents: the bbox selection handle (BboxOverlayView) and the
            active-region badge / row highlight. Plugin-owned drawing, not Material.
          - plugin_error — error text in the plugin's own layouts.

        Light values here; dark in values-night/colors.xml (keep the two in sync).
    -->
    <!-- Plugin-owned accent (forest green) — bbox handle + active-region highlight -->
    <color name="plugin_primary">#1F6B4D</color>
    <color name="plugin_primary_container">#A6F2CE</color>

    <!-- Error — the plugin's own error text -->
    <color name="plugin_error">#BA1A1A</color>

    <!-- Surface / text / outline — used by the plugin's own layouts via ?attr/* -->
    <color name="plugin_surface">#FBFDF8</color>
    <color name="plugin_on_surface">#191C1A</color>
    <color name="plugin_surface_variant">#D9E4DC</color>
    <color name="plugin_on_surface_variant">#404943</color>
    <color name="plugin_outline">#707974</color>
    <color name="plugin_outline_variant">#BFC9C1</color>
</resources>
