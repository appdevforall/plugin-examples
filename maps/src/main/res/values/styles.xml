<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="PluginTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/plugin_primary</item>
        <item name="colorOnPrimary">@color/plugin_on_primary</item>
        <item name="colorPrimaryContainer">@color/plugin_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/plugin_on_primary_container</item>
        <item name="colorSecondary">@color/plugin_secondary</item>
        <item name="colorOnSecondary">@color/plugin_on_secondary</item>
        <item name="colorSurface">@color/plugin_surface</item>
        <item name="colorOnSurface">@color/plugin_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/plugin_on_surface_variant</item>
        <item name="colorOutline">@color/plugin_outline</item>
        <item name="colorOutlineVariant">@color/plugin_outline_variant</item>
        <item name="colorError">@color/plugin_error</item>
        <item name="colorOnError">@color/plugin_on_error</item>

        <!-- Override host materialButtonStyle so MaterialButton anchors on
             the plugin's M3 palette. Without this, MaterialButton's internal
             ColorStateList resolution can leak the host's Material You seed
             colors into our widgets even with the inflater-wrap pattern. -->
        <item name="materialButtonStyle">@style/Plugin.Button.Filled</item>
    </style>

    <!--
        Button styles for the Maps plugin. Mirrors the Forms plugin's
        Plugin.Button.* convention; same style names + variants, swapped
        color references. Use these in layouts instead of `Widget.Material3.Button.*`
        so the plugin's palette wins over the host's seed colors.

        Variants:
          - Plugin.Button.Filled    — primary CTA. Filled with colorPrimary, white text.
          - Plugin.Button.Outlined  — secondary action. Outlined, primary-color text.
          - Plugin.Button.Text      — low-priority action. No bg, primary-color text.
          - Plugin.Button.Tonal     — a step down from filled. Container color bg.

        Shape: pill (M3 default ~28dp). Matches the team's recent layouts
        (cv-image-to-xml, layout_project_filters_sheet, etc.) — no explicit
        cornerRadius override needed.
    -->
    <!--
        ThemeOverlay carrying ONLY the M3 color tokens MaterialButton's
        internal ColorStateList selectors care about. Mirrors the Forms plugin
        pattern — see Forms styles.xml's Plugin.Button.Overlay for the
        rationale. Anchors MaterialButton's `?attr/colorOnPrimary` lookup on
        the plugin's palette rather than the host's seed colors.
    -->
    <style name="Plugin.Button.Overlay" parent="">
        <item name="colorPrimary">@color/plugin_primary</item>
        <item name="colorOnPrimary">@color/plugin_on_primary</item>
        <item name="colorPrimaryContainer">@color/plugin_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/plugin_on_primary_container</item>
        <item name="colorOnSurface">@color/plugin_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/plugin_on_surface_variant</item>
        <item name="colorOutline">@color/plugin_outline</item>
    </style>

    <style name="Plugin.Button.Filled" parent="Widget.Material3.Button">
        <item name="materialThemeOverlay">@style/Plugin.Button.Overlay</item>
    </style>

    <style name="Plugin.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="materialThemeOverlay">@style/Plugin.Button.Overlay</item>
    </style>

    <style name="Plugin.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="materialThemeOverlay">@style/Plugin.Button.Overlay</item>
    </style>

    <style name="Plugin.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="materialThemeOverlay">@style/Plugin.Button.Overlay</item>
    </style>
</resources>
