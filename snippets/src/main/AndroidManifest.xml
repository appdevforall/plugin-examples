<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:label="Custom Snippets"
        android:theme="@style/PluginTheme">

        <meta-data
            android:name="plugin.id"
            android:value="com.codeonthego.snippets" />

        <meta-data
            android:name="plugin.name"
            android:value="Custom Snippets" />

        <meta-data
            android:name="plugin.version"
            android:value="${pluginVersion}" />

        <meta-data
            android:name="plugin.description"
            android:value="Add custom code snippets to the editor. Define your own snippets in .codeonthego/snippets.json." />

        <meta-data
            android:name="plugin.author"
            android:value="App Dev For All" />

        <meta-data
            android:name="plugin.min_ide_version"
            android:value="1.0.0" />

        <meta-data
            android:name="plugin.permissions"
            android:value="filesystem.read,filesystem.write" />

        <meta-data
            android:name="plugin.main_class"
            android:value="com.codeonthego.snippets.SnippetsPlugin" />

        <meta-data
            android:name="plugin.sidebar_items"
            android:value="1" />

    </application>

</manifest>